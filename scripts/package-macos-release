#!/usr/bin/env bash
set -euo pipefail

version=""
arm64_bin_dir=""
x86_64_bin_dir=""
output_dir=""
base_url=""
extension_identity=""
team_id=""
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version)
      version="${2:-}"
      shift 2
      ;;
    --arm64-bin-dir)
      arm64_bin_dir="${2:-}"
      shift 2
      ;;
    --x86_64-bin-dir)
      x86_64_bin_dir="${2:-}"
      shift 2
      ;;
    --output-dir)
      output_dir="${2:-}"
      shift 2
      ;;
    --base-url)
      base_url="${2:-}"
      shift 2
      ;;
    --extension-identity)
      extension_identity="${2:-}"
      shift 2
      ;;
    --team-id)
      team_id="${2:-}"
      shift 2
      ;;
    *)
      printf '未知参数：%s\n' "$1" >&2
      exit 2
      ;;
  esac
done

if [[ ! "${version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.-]+)?$ ]]; then
  printf '版本号无效：%s\n' "${version}" >&2
  exit 2
fi
if [[ -z "${arm64_bin_dir}" || -z "${x86_64_bin_dir}" || -z "${output_dir}" || -z "${base_url}" || -z "${extension_identity}" || ! "${team_id}" =~ ^[A-Z0-9]{10}$ ]]; then
  printf '%s\n' '必须提供两个架构的 bin 目录、输出目录、发布基础 URL、扩展身份文件和 10 位 Apple Team ID。' >&2
  exit 2
fi
node_bin="$("${script_dir}/find-node")"
extension_id="$("${node_bin}" "${script_dir}/extension-identity.mjs" "${extension_identity}" extension_id)"

base_url="${base_url%/}"
mkdir -p "${output_dir}"
output_dir="$(cd "${output_dir}" && pwd)"
temporary_root="$(mktemp -d "${output_dir}/.package.XXXXXX")"
trap 'rm -rf "${temporary_root}"' EXIT
rendered_installer="${temporary_root}/install.sh"
"${node_bin}" "${script_dir}/render-installer.mjs" "${script_dir}/install.sh" "${rendered_installer}" "${team_id}"

package_architecture() {
  local architecture="$1"
  local binary_directory="$2"
  local archive_name="agent-ferry-v${version}-darwin-${architecture}.tar.gz"
  local package_root="${temporary_root}/agent-ferry-v${version}-darwin-${architecture}"
  local binary

  mkdir -p "${package_root}/bin"
  for binary in aferry agentferryd agentferry-host; do
    if [[ ! -x "${binary_directory}/${binary}" ]]; then
      printf '缺少可执行文件：%s\n' "${binary_directory}/${binary}" >&2
      exit 1
    fi
    cp "${binary_directory}/${binary}" "${package_root}/bin/${binary}"
    chmod 755 "${package_root}/bin/${binary}"
  done
  mkdir -p "${package_root}/share"
  cp "${rendered_installer}" "${package_root}/share/install.sh"
  chmod 755 "${package_root}/share/install.sh"
  COPYFILE_DISABLE=1 tar -czf "${output_dir}/${archive_name}" -C "${temporary_root}" "$(basename "${package_root}")"
  /usr/bin/shasum -a 256 "${output_dir}/${archive_name}" | awk '{print $1}'
}

arm64_sha="$(package_architecture arm64 "${arm64_bin_dir}")"
x86_64_sha="$(package_architecture x86_64 "${x86_64_bin_dir}")"
manifest="${output_dir}/release-manifest.json"
/usr/bin/plutil -create xml1 "${manifest}"
/usr/bin/plutil -insert schema_version -integer 1 "${manifest}"
/usr/bin/plutil -insert version -string "${version}" "${manifest}"
/usr/bin/plutil -insert signing_team_id -string "${team_id}" "${manifest}"
/usr/bin/plutil -insert artifacts -dictionary "${manifest}"
for architecture in arm64 x86_64; do
  /usr/bin/plutil -insert "artifacts.darwin-${architecture}" -dictionary "${manifest}"
done
/usr/bin/plutil -insert artifacts.darwin-arm64.url -string \
  "${base_url}/agent-ferry-v${version}-darwin-arm64.tar.gz" "${manifest}"
/usr/bin/plutil -insert artifacts.darwin-arm64.sha256 -string "${arm64_sha}" "${manifest}"
/usr/bin/plutil -insert artifacts.darwin-x86_64.url -string \
  "${base_url}/agent-ferry-v${version}-darwin-x86_64.tar.gz" "${manifest}"
/usr/bin/plutil -insert artifacts.darwin-x86_64.sha256 -string "${x86_64_sha}" "${manifest}"
/usr/bin/plutil -insert extension_id -string "${extension_id}" "${manifest}"
/usr/bin/plutil -convert json -r "${manifest}"
chmod 644 "${manifest}"

printf '%s  %s\n' "${arm64_sha}" "agent-ferry-v${version}-darwin-arm64.tar.gz" >"${output_dir}/checksums.txt"
printf '%s  %s\n' "${x86_64_sha}" "agent-ferry-v${version}-darwin-x86_64.tar.gz" >>"${output_dir}/checksums.txt"
printf '已生成 macOS Agent Ferry %s 发布包：%s\n' "${version}" "${output_dir}"
