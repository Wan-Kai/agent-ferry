#!/usr/bin/env bash
set -euo pipefail

version=""
arm64_bin_dir=""
x86_64_bin_dir=""
output_dir=""
base_url=""
extension_identity=""
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repository_root="$(cd "${script_dir}/.." && pwd)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --version) version="${2:-}"; shift 2 ;;
    --arm64-bin-dir) arm64_bin_dir="${2:-}"; shift 2 ;;
    --x86_64-bin-dir) x86_64_bin_dir="${2:-}"; shift 2 ;;
    --output-dir) output_dir="${2:-}"; shift 2 ;;
    --base-url) base_url="${2:-}"; shift 2 ;;
    --extension-identity) extension_identity="${2:-}"; shift 2 ;;
    *) printf '未知参数：%s\n' "$1" >&2; exit 2 ;;
  esac
done

if [[ -z "${version}" || -z "${arm64_bin_dir}" || -z "${x86_64_bin_dir}" ||
      -z "${output_dir}" || -z "${base_url}" || -z "${extension_identity}" ]]; then
  printf '%s\n' '必须提供 version、双架构 bin 目录、output-dir、base-url 和 extension-identity。' >&2
  exit 2
fi
if [[ "$(uname -s)" != "Darwin" ]]; then
  printf '%s\n' 'Homebrew macOS 发行包只能在 macOS 上生成。' >&2
  exit 1
fi

node_bin="$("${script_dir}/find-node")"
"${node_bin}" "${script_dir}/check-release-version.mjs" "${version}"
"${node_bin}" "${script_dir}/extension-identity.mjs" "${extension_identity}" >/dev/null
extension_id="$(/usr/bin/plutil -extract extension_id raw -o - "${extension_identity}")"
mkdir -p "${output_dir}"
temporary_root="$(mktemp -d "${TMPDIR:-/tmp}/agent-ferry-homebrew-release.XXXXXX")"
trap 'rm -rf "${temporary_root}"' EXIT

package_architecture() {
  local architecture="$1"
  local source_dir="$2"
  local package_name="agent-ferry-v${version}-darwin-${architecture}"
  local package_root="${temporary_root}/${package_name}"
  local archive="${output_dir}/${package_name}.tar.gz"
  mkdir -p "${package_root}/bin"
  for binary in aferry agentferryd agentferry-host; do
    if [[ ! -x "${source_dir}/${binary}" ]]; then
      printf '缺少可执行文件：%s/%s\n' "${source_dir}" "${binary}" >&2
      exit 1
    fi
    cp "${source_dir}/${binary}" "${package_root}/bin/${binary}"
    chmod 755 "${package_root}/bin/${binary}"
    # Apple Silicon 要求 Mach-O 具有代码签名结构；ad-hoc 签名只保证文件结构完整，
    # 不冒充 Developer ID 身份，真正的来源完整性由 Formula SHA256 和 GitHub 证据承担。
    /usr/bin/codesign --force --sign - \
      --identifier "com.agentferry.${binary}" "${package_root}/bin/${binary}"
    /usr/bin/codesign --verify --strict "${package_root}/bin/${binary}"
  done
  /usr/bin/tar -czf "${archive}" -C "${temporary_root}" "${package_name}"
  /usr/bin/shasum -a 256 "${archive}" | awk '{print $1}'
}

arm64_sha="$(package_architecture arm64 "${arm64_bin_dir}")"
x86_64_sha="$(package_architecture x86_64 "${x86_64_bin_dir}")"
base_url="${base_url%/}"
arm64_name="agent-ferry-v${version}-darwin-arm64.tar.gz"
x86_64_name="agent-ferry-v${version}-darwin-x86_64.tar.gz"

"${node_bin}" "${script_dir}/render-homebrew-formula.mjs" \
  "${repository_root}/release/homebrew/agent-ferry.rb.in" \
  "${output_dir}/agent-ferry.rb" \
  "${version}" \
  "${base_url}/${arm64_name}" "${arm64_sha}" \
  "${base_url}/${x86_64_name}" "${x86_64_sha}" \
  "${extension_id}"

(
  cd "${output_dir}"
  /usr/bin/shasum -a 256 "${arm64_name}" "${x86_64_name}" agent-ferry.rb > checksums.txt
)
printf 'Homebrew 发行包已生成：%s\n' "${output_dir}"
