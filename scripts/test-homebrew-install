#!/usr/bin/env bash
set -euo pipefail

if [[ "$(uname -s)" != "Darwin" ]]; then
  printf '%s\n' '跳过真实 Homebrew Bottle 安装验收：当前不是 macOS。'
  exit 0
fi

version=""
distribution_dir=""
expected_tag=""
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repository_root="$(cd "${script_dir}/.." && pwd)"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --version) version="${2:-}"; shift 2 ;;
    --distribution-dir) distribution_dir="${2:-}"; shift 2 ;;
    --expected-tag) expected_tag="${2:-}"; shift 2 ;;
    *) printf '未知参数：%s\n' "$1" >&2; exit 2 ;;
  esac
done
if [[ -z "${version}" || -z "${distribution_dir}" || -z "${expected_tag}" ]]; then
  printf '%s\n' '必须提供 version、distribution-dir 和 expected-tag。' >&2
  exit 2
fi
if [[ ! "${version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][A-Za-z0-9.-]+)?$ ]]; then
  printf '无效版本号：%s\n' "${version}" >&2
  exit 2
fi
if [[ ! "${expected_tag}" =~ ^(arm64_)?[a-z][a-z0-9_]*$ ]]; then
  printf '无效 Bottle tag：%s\n' "${expected_tag}" >&2
  exit 2
fi
if [[ ! -d "${distribution_dir}" ]]; then
  printf '发行目录不存在：%s\n' "${distribution_dir}" >&2
  exit 1
fi
distribution_dir="$(cd "${distribution_dir}" && pwd)"

brew_bin="${AGENT_FERRY_BREW_BIN:-/opt/homebrew/bin/brew}"
if [[ ! -x "${brew_bin}" ]]; then
  brew_bin="/usr/local/bin/brew"
fi
if [[ ! -x "${brew_bin}" ]]; then
  printf '%s\n' '未找到 Homebrew，无法执行真实 Bottle 安装验收。' >&2
  exit 1
fi
if "${brew_bin}" list --versions agent-ferry >/dev/null 2>&1; then
  printf '%s\n' '真实 Homebrew 验收要求 agent-ferry 尚未安装，避免覆盖用户现有 keg。' >&2
  exit 1
fi

arm64_source="agent-ferry-v${version}-darwin-arm64.tar.gz"
x86_source="agent-ferry-v${version}-darwin-x86_64.tar.gz"
arm64_bottle="agent-ferry-${version}.arm64_sonoma.bottle.tar.gz"
x86_bottle="agent-ferry-${version}.sequoia.bottle.tar.gz"
for artifact in "${arm64_source}" "${x86_source}" "${arm64_bottle}" "${x86_bottle}"; do
  if [[ ! -f "${distribution_dir}/${artifact}" ]]; then
    printf '缺少 Homebrew 发行产物：%s\n' "${distribution_dir}/${artifact}" >&2
    exit 1
  fi
done

temporary_root="$(mktemp -d "${TMPDIR:-/tmp}/agent-ferry-homebrew-e2e.XXXXXX")"
test_home="${temporary_root}/home with spaces"
launchctl="${temporary_root}/fake-launchctl"
formula="${temporary_root}/agent-ferry.rb"
install_log="${temporary_root}/brew-install.log"
mkdir -p "${test_home}" "${test_home}/tmp"
installed="false"
tap_name="agent-ferry/e2e"
tap_created="false"

cleanup() {
  if [[ "${installed}" == "true" ]]; then
    HOME="${test_home}" \
      TMPDIR="${test_home}/tmp" \
      AGENT_FERRY_HOME="${test_home}/.agent-ferry" \
      AFERRY_LAUNCHCTL_PATH="${launchctl}" \
      "$("${brew_bin}" --prefix agent-ferry)/bin/aferry" uninstall >/dev/null 2>&1 || true
    HOMEBREW_NO_AUTO_UPDATE=1 "${brew_bin}" uninstall --force agent-ferry >/dev/null 2>&1 || true
  fi
  if [[ "${tap_created}" == "true" ]]; then
    HOMEBREW_NO_AUTO_UPDATE=1 "${brew_bin}" untap --force "${tap_name}" >/dev/null 2>&1 || true
  fi
  rm -rf "${temporary_root}"
}
trap cleanup EXIT

printf '%s\n' \
  '#!/bin/sh' \
  'printf "%s\n" "$*" >> "$HOME/launchctl-arguments.log"' \
  'case "$1" in' \
  '  manageruid) printf "%s\n" 501 ;;' \
  '  print)' \
  '    if [ -f "$HOME/launchctl-loaded" ]; then' \
  '      printf "%s\n" "state = running" "pid = 2468"' \
  '    else' \
  '      exit 113' \
  '    fi' \
  '    ;;' \
  '  bootstrap) : > "$HOME/launchctl-loaded" ;;' \
  '  bootout) rm -f "$HOME/launchctl-loaded" ;;' \
  '  *) exit 64 ;;' \
  'esac' >"${launchctl}"
chmod 700 "${launchctl}"

arm64_source_sha="$(shasum -a 256 "${distribution_dir}/${arm64_source}" | awk '{print $1}')"
x86_source_sha="$(shasum -a 256 "${distribution_dir}/${x86_source}" | awk '{print $1}')"
arm64_bottle_sha="$(shasum -a 256 "${distribution_dir}/${arm64_bottle}" | awk '{print $1}')"
x86_bottle_sha="$(shasum -a 256 "${distribution_dir}/${x86_bottle}" | awk '{print $1}')"
extension_id="$(plutil -extract extension_id raw -o - "${repository_root}/release/chrome-extension-identity.json")"
node_bin="$("${script_dir}/find-node")"
"${node_bin}" "${script_dir}/render-homebrew-formula.mjs" \
  "${repository_root}/release/homebrew/agent-ferry.rb.in" \
  "${formula}" \
  "${version}" \
  "file://${distribution_dir}/${arm64_source}" "${arm64_source_sha}" \
  "file://${distribution_dir}/${x86_source}" "${x86_source_sha}" \
  "${extension_id}" \
  --bottle-root-url "file://${distribution_dir}" \
  --arm64-bottle-tag arm64_sonoma \
  --arm64-bottle-sha "${arm64_bottle_sha}" \
  --x86-64-bottle-tag sequoia \
  --x86-64-bottle-sha "${x86_bottle_sha}"

HOMEBREW_NO_AUTO_UPDATE=1 "${brew_bin}" tap-new "${tap_name}" >/dev/null
tap_created="true"
tap_root="$("${brew_bin}" --repo "${tap_name}")"
mkdir -p "${tap_root}/Formula"
cp "${formula}" "${tap_root}/Formula/agent-ferry.rb"
HOMEBREW_NO_AUTO_UPDATE=1 "${brew_bin}" trust --formula "${tap_name}/agent-ferry"

# `fetch --force-bottle` 和安装日志共同证明 Formula 没有退回会触发 CLT 检查的源码路径。
HOMEBREW_NO_AUTO_UPDATE=1 "${brew_bin}" fetch \
  --force-bottle "${tap_name}/agent-ferry" >/dev/null
HOMEBREW_NO_AUTO_UPDATE=1 "${brew_bin}" install \
  --skip-post-install "${tap_name}/agent-ferry" 2>&1 | tee "${install_log}"
installed="true"
grep -q "Pouring agent-ferry-${version}.${expected_tag}.bottle.tar.gz" "${install_log}"

prefix="$("${brew_bin}" --prefix agent-ferry)"
aferry="${prefix}/bin/aferry"
[[ "$("${aferry}" --version)" == "aferry ${version}" ]]
HOME="${test_home}" \
  TMPDIR="${test_home}/tmp" \
  AGENT_FERRY_HOME="${test_home}/.agent-ferry" \
  AFERRY_LAUNCHCTL_PATH="${launchctl}" \
  "${aferry}" service install --daemon-path "${prefix}/bin/agentferryd" >/dev/null
HOME="${test_home}" \
  TMPDIR="${test_home}/tmp" \
  AGENT_FERRY_HOME="${test_home}/.agent-ferry" \
  "${aferry}" native-host register \
    --extension-id "${extension_id}" \
    --host-path "${prefix}/bin/agentferry-host" >/dev/null
HOME="${test_home}" \
  AGENT_FERRY_HOME="${test_home}/.agent-ferry" \
  AFERRY_LAUNCHCTL_PATH="${launchctl}" \
  "${aferry}" service status --json | grep -q '"state": "running"'

manifest="${test_home}/Library/Application Support/Google/Chrome/NativeMessagingHosts/com.agentferry.host.json"
[[ -f "${manifest}" ]]
plutil -extract allowed_origins.0 raw -o - "${manifest}" |
  grep -q "^chrome-extension://${extension_id}/$"
plutil -extract path raw -o - "${manifest}" | grep -q '/opt/agent-ferry/bin/agentferry-host$'

log_dir="${test_home}/Library/Logs/Agent Ferry"
mkdir -p "${log_dir}"
printf '%s\n' 'homebrew-bottle-e2e-log' >"${log_dir}/agentferryd.log"
HOME="${test_home}" \
  AGENT_FERRY_HOME="${test_home}/.agent-ferry" \
  AFERRY_LAUNCHCTL_PATH="${launchctl}" \
  "${aferry}" service logs --lines 10 | grep -q 'homebrew-bottle-e2e-log'

uninstall_report="${temporary_root}/uninstall.json"
HOME="${test_home}" \
  TMPDIR="${test_home}/tmp" \
  AGENT_FERRY_HOME="${test_home}/.agent-ferry" \
  AFERRY_LAUNCHCTL_PATH="${launchctl}" \
  "${aferry}" uninstall --json >"${uninstall_report}"
grep -q '"program": "managed_externally"' "${uninstall_report}"
[[ -x "${aferry}" ]]
[[ ! -e "${manifest}" ]]
[[ ! -e "${test_home}/Library/LaunchAgents/com.agentferry.daemon.plist" ]]

HOMEBREW_NO_AUTO_UPDATE=1 "${brew_bin}" uninstall "${tap_name}/agent-ferry" >/dev/null
installed="false"
if "${brew_bin}" list --versions agent-ferry >/dev/null 2>&1; then
  printf '%s\n' 'Homebrew 卸载后仍能找到 agent-ferry keg。' >&2
  exit 1
fi
HOMEBREW_NO_AUTO_UPDATE=1 "${brew_bin}" untap --force "${tap_name}" >/dev/null
tap_created="false"
printf '真实 Homebrew Bottle 下载、安装、激活、状态、日志和双阶段卸载通过；Bottle tag：%s\n' "${expected_tag}"
