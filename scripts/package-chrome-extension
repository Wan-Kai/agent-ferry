#!/usr/bin/env bash
set -euo pipefail

identity=""
output_dir=""
script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repository_root="$(cd "${script_dir}/.." && pwd)"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --extension-identity)
      identity="${2:-}"
      shift 2
      ;;
    --output-dir)
      output_dir="${2:-}"
      shift 2
      ;;
    *)
      printf '未知参数：%s\n' "$1" >&2
      exit 2
      ;;
  esac
done

if [[ -z "${identity}" || -z "${output_dir}" ]]; then
  printf '%s\n' '必须提供 --extension-identity 和 --output-dir。' >&2
  exit 2
fi

node_bin="$("${script_dir}/find-node")"
node_directory="$(dirname "${node_bin}")"
npm_bin="${node_directory}/npm"
identity="$(cd "$(dirname "${identity}")" && pwd)/$(basename "${identity}")"
extension_id="$("${node_bin}" "${script_dir}/extension-identity.mjs" "${identity}" extension_id)"
manifest_key="$("${node_bin}" "${script_dir}/extension-identity.mjs" "${identity}" manifest_key)"
version="$("${node_bin}" -p 'require(process.argv[1]).version' "${repository_root}/extension/package.json")"

mkdir -p "${output_dir}"
output_dir="$(cd "${output_dir}" && pwd)"
PATH="${node_directory}:${PATH}" \
AGENT_FERRY_EXTENSION_IDENTITY="${identity}" \
  "${npm_bin}" --prefix "${repository_root}/extension" run zip:release >/dev/null

source_zip="${repository_root}/extension/dist/agent-ferry-extension-${version}-chrome.zip"
if [[ ! -f "${source_zip}" ]]; then
  printf '扩展构建没有生成预期 ZIP：%s\n' "${source_zip}" >&2
  exit 1
fi

temporary_root="$(mktemp -d "${output_dir}/.extension.XXXXXX")"
trap 'rm -rf "${temporary_root}"' EXIT
/usr/bin/unzip -p "${source_zip}" manifest.json >"${temporary_root}/manifest.json"
built_key="$("${node_bin}" -p 'require(process.argv[1]).key' "${temporary_root}/manifest.json")"
if [[ "${built_key}" != "${manifest_key}" ]]; then
  printf '%s\n' '扩展 ZIP 中的 manifest key 与发行身份文件不一致。' >&2
  exit 1
fi

destination="${output_dir}/agent-ferry-extension-v${version}-chrome.zip"
cp "${source_zip}" "${destination}"
/usr/bin/shasum -a 256 "${destination}" >"${destination}.sha256"
printf '已生成 Chrome 扩展 %s（ID %s）：%s\n' "${version}" "${extension_id}" "${destination}"
